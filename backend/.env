# Grand Telecom Backend - Environment Variables
# DIQQET: Bu fayl gizli saxlanmalıdır. Heç vaxt git-ə əlavə etməyin!

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/grandtelecom

# Superadmin credentials (default-lardan mütləq dəyiştirin!)
SUPERADMIN_USERNAME=Timur
SUPERADMIN_PASSWORD=TE07102024

# Token secret (produksiyada mütləq güclü, unikal dəyər yazın!)
# Aşağıdakı kimi generasiya edə bilərsiniz: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
TOKEN_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_BEFORE_PRODUCTION

# Bcrypt rounds (12 tövsiyə olunur)
BCRYPT_ROUNDS=12

# CORS (produksiyada yalnız öz domeninizi yazın)
# ALLOWED_ORIGINS=https://grandtelecom.az,https://www.grandtelecom.az
